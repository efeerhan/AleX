<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ============================================================
         TYPE SCALE  ·  All sans-serif (Roboto); hierarchy via size + weight.

         IMPORTANT: both `fontFamily` (AppCompat, no prefix) AND
         `android:fontFamily` are set. AppCompatTextView reads the
         un-prefixed `fontFamily` first, and the Material3 parent
         appearances set it — so setting only android:fontFamily is
         silently ignored. Keep the two in sync. To adopt custom fonts
         later (e.g. Playfair Display + Inter) swap both lines per style.
         ============================================================ -->

    <style name="TextAppearance.AleX.Display" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textFontWeight">600</item>
        <item name="android:textSize">34sp</item>
        <item name="android:letterSpacing">-0.015</item>
        <item name="android:textColor">@color/ink</item>
    </style>

    <style name="TextAppearance.AleX.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">26sp</item>
        <item name="android:letterSpacing">-0.01</item>
        <item name="android:textColor">@color/ink</item>
    </style>

    <style name="TextAppearance.AleX.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/ink</item>
    </style>

    <style name="TextAppearance.AleX.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/ink</item>
    </style>

    <style name="TextAppearance.AleX.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/ink</item>
    </style>

    <style name="TextAppearance.AleX.Label" parent="TextAppearance.Material3.LabelLarge">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textColor">@color/ink</item>
    </style>

    <style name="TextAppearance.AleX.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/ink_muted</item>
    </style>

    <!-- ============================================================
         BUTTONS
         ============================================================ -->

    <!-- Primary call-to-action.
         Container = colorPrimary (amber), label = colorOnPrimary (ink),
         both inherited from the theme so we only tune shape + typography. -->
    <style name="Widget.AleX.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:minHeight">@dimen/touch_target</item>
        <item name="android:paddingTop">@dimen/space_md</item>
        <item name="android:paddingBottom">@dimen/space_md</item>
    </style>

    <!-- Secondary / neutral action: muted surface, ink label -->
    <style name="Widget.AleX.Button.Secondary">
        <item name="android:backgroundTint">@color/surface_muted</item>
        <item name="android:textColor">@color/ink</item>
    </style>

    <!-- ============================================================
         INPUT FIELDS
         ============================================================ -->

    <style name="Widget.AleX.EditText" parent="Widget.AppCompat.EditText">
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:textColorHint">@color/ink_muted</item>
        <item name="android:background">@drawable/field_background</item>
        <item name="android:paddingHorizontal">@dimen/space_lg</item>
        <item name="android:paddingVertical">@dimen/space_md</item>
        <item name="android:minHeight">@dimen/touch_target</item>
    </style>

    <!-- ============================================================
         IMAGE SHAPES
         ============================================================ -->

    <style name="ShapeAppearance.AleX.Thumbnail" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_sm</item>
    </style>

    <!-- Larger hero/preview images (add + view screens) -->
    <style name="ShapeAppearance.AleX.Image" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_md</item>
    </style>

    <!-- Kept for backwards-compatibility with existing references -->
    <style name="roundedImageView" parent="ShapeAppearance.AleX.Thumbnail" />

    <!-- Global component shapes — keeps Material dialogs, menus, date picker,
         and default buttons on the same radius scale as everything else. -->
    <style name="ShapeAppearance.AleX.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">@dimen/radius_sm</item>
    </style>

    <style name="ShapeAppearance.AleX.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">@dimen/radius_md</item>
    </style>

    <style name="ShapeAppearance.AleX.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSize">@dimen/radius_lg</item>
    </style>

</resources>
