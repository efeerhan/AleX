    <dimen name="space_xl">24dp</dimen>
    <dimen name="space_2xl">32dp</dimen>
    <dimen name="space_3xl">48dp</dimen>
    <dimen name="space_4xl">64dp</dimen>

    <!-- Corner radius scale -->
    <dimen name="radius_sm">8dp</dimen>
    <dimen name="radius_md">16dp</dimen>
    <dimen name="radius_lg">24dp</dimen>
    <dimen name="radius_pill">100dp</dimen>

