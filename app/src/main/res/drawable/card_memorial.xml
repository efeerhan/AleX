<?xml version="1.0" encoding="utf-8"?>
<!--
    The memorial row's card. Deliberately unlike @drawable/card: muted fill, no elevation,
    and a dashed outline, so the row reads as an absence in the list rather than an entry.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/surface_muted" />
    <stroke
        android:width="1dp"
        android:color="@color/outline"
        android:dashWidth="6dp"
        android:dashGap="4dp" />
    <corners android:radius="@dimen/radius_md" />
</shape>
